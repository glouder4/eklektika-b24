Options -Indexes 
ErrorDocument 404 /404.php

#php_value session.gc_maxlifetime 10800
#php_value session.cookie_lifetime 10800

php_value session.gc_maxlifetime 172800
php_value session.cookie_lifetime 172800
php_value session.gc_probability 1
php_value session.gc_divisor 5000

# Разрешаем сессии для AJAX
SetEnvIf Request_URI "/ajax/" SESSION_NEEDED=1
SetEnvIf Request_URI "/services/main/ajax.php" SESSION_NEEDED=1

# Отключаем кэш для AJAX
<FilesMatch "ajax\.php$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
</FilesMatch>

<IfModule mod_rewrite.c>
	Options +FollowSymLinks
	RewriteEngine On
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-l
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_FILENAME} !/bitrix/urlrewrite.php$
	RewriteRule ^(.*)$ /bitrix/urlrewrite.php [L]
	RewriteRule .* - [E=REMOTE_USER:%{HTTP:Authorization}]
</IfModule>

<IfModule mod_dir.c>
	DirectoryIndex index.php index.html
</IfModule>

<IfModule mod_expires.c>
	ExpiresActive on
	ExpiresByType image/jpeg "access plus 3 day"
	ExpiresByType image/gif "access plus 3 day"
</IfModule>